{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "#build/ui/*": ["./node_modules/.nuxt-ui/ui/*"]
    },
    "types": [
      "unplugin-icons/types/vue3"
    ]
  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    "src/env.d.ts",
    "src/auto-imports.d.ts",
    "src/components.d.ts"
  ]
}
